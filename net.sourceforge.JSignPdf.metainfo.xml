  <name>JSignPdf</name>
  <summary>Add digital signatures to PDF documents</summary>
  <developer id="net.sourceforge.jsignpdf">
    <name>JSignPdf Project</name>
  </developer>
  <description>
    <p>JSignPdf is a free, open source application that adds digital signatures to PDF documents. It supports visible and hidden signatures, certificate levels, timestamping, and batch processing from the command line.</p>
    <p>Features:</p>
    <ul>
      <li>Visible and hidden digital signatures</li>
      <li>Certificate levels and timestamping (TSA)</li>
      <li>PDF encryption and rights management</li>
      <li>Certificate revocation checks (CRL, OCSP)</li>
      <li>Command-line batch processing</li>
      <li>PKCS#11 hardware token support</li>
    </ul>
  </description>
  <launchable type="desktop-id">net.sourceforge.JSignPdf.desktop</launchable>
  <url type="homepage">https://jsignpdf.sourceforge.net/</url>
  <url type="bugtracker">https://sourceforge.net/p/jsignpdf/bugs-change-requests/</url>
